{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loreforge",
  "version": "1.1.0",
  "identifier": "com.loreforge.app",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File sync-ui.ps1",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File sync-ui.ps1"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Loreforge",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
